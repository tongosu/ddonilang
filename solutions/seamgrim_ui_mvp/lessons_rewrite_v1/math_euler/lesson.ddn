#기본관찰x: t
#기본관찰: y

채비 {
  y0: 수 = (1.0) 매김 { 범위: 0.1..5.0. 간격: 0.1. }.
  k: 수 = (1.0) 매김 { 범위: 0.1..3.0. 간격: 0.1. }.
  y: 수 <- 0.0.
  t: 수 <- 0.0.
  dt: 수 = (0.05) 매김 { 범위: 0.01..0.2. 간격: 0.01. }.
  t_max: 수 = (6.0) 매김 { 범위: 1.0..12.0. 간격: 0.5. }.
}.

(시작)할때 {
  y <- y0.
}.

(매마디)마다 {
  { t <= t_max }인것 일때 {
    y <- y + (k * y * dt).
    보임 {
      값1: t.
      값2: y.
    }.
    t <- t + dt.
  }.
}.
