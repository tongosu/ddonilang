채비: {
  m:수 <- (1) 매김 { 범위: -10..10. 간격: 0.1. }.
  b:수 <- (0) 매김 { 범위: -20..20. 간격: 0.1. }.
  x_start:수 <- (-5) 매김 { 범위: -20..20. 간격: 0.5. }.
  x_end:수 <- (5) 매김 { 범위: -20..20. 간격: 0.5. }.
  dx:수 <- (0.25) 매김 { 범위: 0.05..1. 간격: 0.05. }.
}.

m <- 1.
b <- 0.
x_start <- -5.
x_end <- 5.
dx <- 0.25.

(시작)할때 {
  x <- x_start.
}.

(매마디)마다 {
  { x <= x_end }인것 일때 {
    y <- m * x + b.
    x 보여주기.
    y 보여주기.
    x <- x + dx.
  }.
}.
