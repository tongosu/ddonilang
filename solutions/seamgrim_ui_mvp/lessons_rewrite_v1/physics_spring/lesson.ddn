#기본관찰x: t
#기본관찰: x

채비 {
  k: 수 = (5.0) 매김 { 범위: 1.0..20.0. 간격: 0.5. }.
  m: 수 = (1.0) 매김 { 범위: 0.2..5.0. 간격: 0.1. }.
  x: 수 <- (1.0) 매김 { 범위: -5.0..5.0. 간격: 0.1. }.
  v: 수 <- 0.0.
  t: 수 <- 0.0.
  dt: 수 = (0.02) 매김 { 범위: 0.005..0.1. 간격: 0.005. }.
}.

(매마디)마다 {
  v <- v + ((-(k / m) * x) * dt).
  x <- x + (v * dt).
  t <- t + dt.

  모양 {
    선(-2.0, 0.0, 2.0, 0.0, 색="#94a3b8", 굵기=0.01).
    점(x, 0.0, 크기=0.07, 색="#38bdf8").
  }.

  보임 {
    값1: t.
    값2: x.
    값3: v.
  }.
}.
