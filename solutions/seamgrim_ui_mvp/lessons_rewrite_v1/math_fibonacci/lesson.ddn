#기본관찰x: n
#기본관찰: f

채비 {
  n_max: 수 = (20.0) 매김 { 범위: 5.0..40.0. 간격: 1.0. }.
  n: 수 <- 0.0.
  a: 수 <- 0.0.
  b: 수 <- 1.0.
  f: 수 <- 0.0.
}.

(시작)할때 {
  n <- 0.0.
  a <- 0.0.
  b <- 1.0.
  f <- 0.0.
}.

(매마디)마다 {
  { n <= n_max }인것 일때 {
    f <- a.
    next <- a + b.
    a <- b.
    b <- next.

    보임 {
      값1: n.
      값2: f.
    }.

    n <- n + 1.0.
  }.
}.
