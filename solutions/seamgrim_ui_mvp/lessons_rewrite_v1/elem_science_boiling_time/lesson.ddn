채비: {
  T_env:수 <- (20) 매김 { 범위: -10..50. 간격: 0.5. }.
  T0:수 <- (90) 매김 { 범위: 0..150. 간격: 0.5. }.
  k:수 <- (0.15) 매김 { 범위: 0.01..1. 간격: 0.01. }.
  dt:수 <- (0.1) 매김 { 범위: 0.02..1. 간격: 0.01. }.
  t_max:수 <- (12) 매김 { 범위: 1..50. 간격: 0.5. }.
}.

T_env <- 20.
T0 <- 90.
k <- 0.15.
dt <- 0.1.
t_max <- 12.

(시작)할때 {
  t <- 0.
  T <- T0.
}.

(매마디)마다 {
  { t <= t_max }인것 일때 {
    dT <- 0 - k * (T - T_env).
    T <- T + dT * dt.
    t <- t + dt.

    t 보여주기.
    T 보여주기.
  }.
}.
