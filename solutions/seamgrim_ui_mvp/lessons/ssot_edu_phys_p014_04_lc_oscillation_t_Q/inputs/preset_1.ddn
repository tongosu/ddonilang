
// stateful-sim preview(auto): range sampler -> step sim
L <- 1.
C <- 1.

dt <- 0.02.
t_max <- 10.



(시작)할때 {
  t <- 0.
  Q <- 1.
  I <- 0.
}.

(매마디)마다 {
  { t <= t_max }인것 일때 {
    보임 {
      t: t.
      Q: Q.
    }.
    
    I <- I + (-(Q / (L * C)) * dt).
    Q <- Q + (I * dt).
    t <- t + (dt).
  }.
}.
