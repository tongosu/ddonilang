
// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 0.
}.

(매마디)마다 {
  x_min <- 0.
  x_max <- 12.
  dx <- 0.5.

  { x <= x_max }인것 일때 {
    y <- 0.
    고르기:
      { x < 4 }인것: { y <- x. }
      { (x >= 4) 그리고 (x < 7) }인것: { y <- 4. }
      아니면: { y <- 4 + (x - 7) * 0.5. }.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (dx).
  }.
}.
