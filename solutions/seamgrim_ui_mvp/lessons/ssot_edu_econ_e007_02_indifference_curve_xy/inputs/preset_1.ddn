#기본관찰x: x
#기본관찰: y

채비 {
  U: 수 <- (10.0) 매김 { 범위: 1..50. 간격: 0.5. }.
  x_min: 수 <- (0.5) 매김 { 범위: 0.1..50. 간격: 0.1. }.
  x_max: 수 <- (50.0) 매김 { 범위: 5..200. 간격: 0.5. }.
  dx: 수 <- (0.5) 매김 { 범위: 0.1..5. 간격: 0.1. }.
}.

(시작)할때 {
  t <- 0.
  x <- x_min.
}.

(매마디)마다 {
  { x <= x_max }인것 일때 {
    U2 <- U * U.
    y <- 0.
    { x > 0 }인것 일때 {
      y <- U2 / x.
    }.

    x <- x + dx.
    t <- t + 1.
  }.
}.
