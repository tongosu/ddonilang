#이름: ssot_edu_phys_p018_04_wien_lambda_max_of_T_variant_P018-04 빈의 법칙 λ_max(T)=b/T
#설명: λ_max = b/T.  온도↑ → 최대파장↓ (짧은 파장으로 이동).

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  T <- 1.0.
}.

(매마디)마다 {
  // 출력은 숫자만. (T, λ_max) 순서.

  b <- 2.9.

  T_min <- 1.0.
  T_max <- 10.0.
  dT <- 0.1.

  { T <= T_max }인것 일때 {
    lam <- b / T.

    보임 {
      T: T.
      lam: lam.
    }.
    T <- T + (dT).
  }.
}.
