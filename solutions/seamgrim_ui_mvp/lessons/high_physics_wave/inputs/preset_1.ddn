#이름: high_physics_wave_variant_high_physics_wave
#설명: y = a t^2 + b t

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  t <- 0.
}.

(매마디)마다 {
  파동 = (#ascii1) 수식{ y = a t^2 + b t }.

  a <- 0.3.
  b <- 0.8.

  { t <= 6 }인것 일때 {
    y <- a t^2 + b t.
    보임 {
      t: t.
      y: y.
    }.
    t <- t + (0.3).
  }.
}.
