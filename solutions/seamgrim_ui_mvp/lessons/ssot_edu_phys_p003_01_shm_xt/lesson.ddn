(매마디)마다 {
  // 출력은 숫자만. (t, x) 순서.

  A <- 1.
  omega <- 2.
  phi <- 0.
  dt <- 0.02.
  t_max <- 10.

  t <- 0.

  { t <= t_max }인것 동안: {
    theta <- (omega=omega, t=t, phi=phi) (#ascii) 수식{ omega*t + phi }.
    s <- (theta) sin.
    x <- (A=A, s=s) (#ascii) 수식{ A*s }.

    보임 {
      값1: t.
      값2: x.
    }.

    t <- t + dt.
  }.
}.
