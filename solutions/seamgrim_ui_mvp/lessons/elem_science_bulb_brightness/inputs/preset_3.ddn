#이름: elem_science_bulb_brightness_variant_전구 개수와 밝기
#설명: y = 2x

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 0.0.
}.

(매마디)마다 {
  x_min <- 0.0.
  x_max <- 10.0.
  dx <- 2.0.

  { x <= x_max }인것 일때 {
    y <- 2 * x.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (dx).
  }.
}.
