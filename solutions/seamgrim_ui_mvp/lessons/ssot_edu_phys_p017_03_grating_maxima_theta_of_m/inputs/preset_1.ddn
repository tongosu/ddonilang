// 출력은 숫자만. (m, θ_deg) 순서.

pi <- 3.1415926535.

d <- 10.0.
lam <- 1.0.

m_min <- -5.
m_max <-  5.
dm <- 1.

k목록 <- (1, 8, 1) 범위.

(시작)할때 {
  m <- m_min.
}.

(매마디)마다 {
  { m <= m_max }인것 일때 {
    r <- (m * lam) / d.    // |r| <= 1

    theta <- r.            // 초기값

    (k) k목록에 대해: {
      s <- (theta) sin.
      c <- (theta) cos.
      theta <- theta - (s - r) / c.
    }.

    deg <- theta * 180 / pi.

    m <- m + dm.
  }.
}.
