#이름: college_econ_productivity_variant_college_econ_productivity
#설명: y = a x^2 + b

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 0.
}.

(매마디)마다 {
  생산 = (#ascii1) 수식{ y = a x^2 + b }.

  a <- 0.1.
  b <- 1.0.

  { x <= 10 }인것 일때 {
    y <- a x^2 + b.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (1).
  }.
}.
