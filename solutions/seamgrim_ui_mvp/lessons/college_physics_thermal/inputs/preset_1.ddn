
// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  t <- 0.
}.

(매마디)마다 {
  온도 = (#ascii1) 수식{ y = a - b*t }.

  a <- 80.
  b <- 4.

  t_max <- 10.
  dt <- 1.

  { t <= t_max }인것 일때 {
    y <- a - b * t.
    tempK <- 273.15@K + y * 1@K.
    섭씨안내 <- (temp=tempK) 글무늬{"{temp|@.1C}"}.
    화씨안내 <- (temp=tempK) 글무늬{"{temp|@.1F}"}.
    보임 {
      t: t.
      y: y.
      celsius: 섭씨안내.
      fahrenheit: 화씨안내.
    }.
    t <- t + (dt).
  }.
}.
