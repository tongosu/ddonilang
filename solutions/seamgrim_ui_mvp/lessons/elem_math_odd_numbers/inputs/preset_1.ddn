#이름: elem_math_odd_numbers_variant_홀수 패턴
#설명: 홀수 수열 상태 시뮬레이션

#기본관찰x: n
#기본관찰: 홀수

채비 {
  시작수: 수 <- (1.0) 매김 { 범위: -99..99. 간격: 2. }.
  공차: 수 <- (2.0) 매김 { 범위: 2..20. 간격: 2. }.
  최대항수: 수 <- (30.0) 매김 { 범위: 5..500. 간격: 1. }.
}.

(시작)할때 {
  n <- 0.
}.

(매마디)마다 {
  { n < 최대항수 }인것 일때 {
    홀수 <- 시작수 + n * 공차.
    이전값 <- 홀수 - 공차.
    간격 <- 홀수 - 이전값.

    보임 {
      n: n.
      홀수: 홀수.
      이전값: 이전값.
      간격: 간격.
    }.

    n <- n + 1.
  }.
}.
