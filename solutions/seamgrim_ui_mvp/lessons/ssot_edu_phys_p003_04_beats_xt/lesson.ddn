(매마디)마다 {
  // 출력은 숫자만. (t, x) 순서.

  A1 <- 1.
  A2 <- 1.
  w1 <- 10.
  w2 <- 11.

  dt <- 0.001.
  t_max <- 2.

  t <- 0.

  { t <= t_max }인것 동안: {
    th1 <- (w=w1, t=t) (#ascii) 수식{ w*t }.
    s1 <- (th1) sin.

    th2 <- (w=w2, t=t) (#ascii) 수식{ w*t }.
    s2 <- (th2) sin.

    x <- (A1=A1, s1=s1, A2=A2, s2=s2) (#ascii) 수식{ A1*s1 + A2*s2 }.

    보임 {
      값1: t.
      값2: x.
    }.

    t <- t + dt.
  }.
}.
