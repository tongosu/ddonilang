#이름: elem_science_boiling_time_variant_가열 시간과 온도
#설명: y = 20 + 3x

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 0.0.
}.

(매마디)마다 {
  x_min <- 0.0.
  x_max <- 10.0.
  dx <- 2.0.

  { x <= x_max }인것 일때 {
    y <- 20 + 3 * x.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (dx).
  }.
}.
