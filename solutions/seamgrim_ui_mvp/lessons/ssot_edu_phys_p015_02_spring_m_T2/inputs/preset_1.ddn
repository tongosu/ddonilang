#이름: ssot_edu_phys_p015_02_spring_m_T2_variant_P015-02 용수철-질량 주기제곱 T²(m)
#설명: 용수철 진동 주기 T = 2π√(m/k). 제곱하면 T² = (4π²/k)·m. (m, T²) 출력.

pi <- 3.141592.
k <- 10.

m_min <- 0.
m_max <- 5.
dm <- 0.05.

coef <- (4 * pi * pi) / k.  # T^2 = coef * m

(시작)할때 {
  m <- m_min.
}.

(매마디)마다 {
  { m <= m_max }인것 일때 {
    T2 <- coef * m.

    보임 {
      m: m.
      T2: T2.
    }.
    m <- m + dm.
  }.
}.
