#이름: 짝수 패턴
#설명: 짝수 수열 상태 시뮬레이션 (간격 2)

#기본관찰x: n
#기본관찰: 짝수

채비 {
  시작수: 수 <- (0.0) 매김 { 범위: -100..100. 간격: 2. }.
  공차: 수 <- (4.0) 매김 { 범위: 2..20. 간격: 2. }.
  최대항수: 수 <- (6.0) 매김 { 범위: 5..500. 간격: 1. }.
}.

(시작)할때 {
  n <- 0.
}.

(매마디)마다 {
  { n < 최대항수 }인것 일때 {
    짝수 <- 시작수 + n * 공차.
    절반 <- 짝수 / 2.

    보임 {
      n: n.
      짝수: 짝수.
      절반: 절반.
      공차: 공차.
    }.

    n <- n + 1.
  }.
}.
