#이름: math_parabola_variant_math_parabola
#설명: 포물선 기본

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- -4.
}.

(매마디)마다 {
  포물선 = (#ascii1) 수식{ y = a x^2 + b x + c }.

  a <- 1.
  b <- 0.
  c <- 0.

  { x <= 4 }인것 일때 {
    y <- a x^2 + b x + c.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (0.5).
  }.
}.
