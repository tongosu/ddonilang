#이름: 진자 운동
#설명: sin 곡선

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 0.
}.

(매마디)마다 {
  A <- 5.
  w <- 0.8.

  x_min <- 0.
  x_max <- 10.
  dx <- 1.

  { x <= x_max }인것 일때 {
    angle <- w * x.
    s <- (angle) sin.
    y <- A * s.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (dx).
  }.
}.
