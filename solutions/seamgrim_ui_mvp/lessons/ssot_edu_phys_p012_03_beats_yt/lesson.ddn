// 출력은 숫자만. (t, y) 순서.

w1 <- 31.415926535.   // 2*pi*5
w2 <- 34.557519190.   // 2*pi*5.5

dt <- 0.001.
t_max <- 2.0.

(시작)할때 {
  t <- 0.
}.

(매마디)마다 {
  { t <= t_max }인것 일때 {
    th1 <- (w=w1, t=t) (#ascii) 수식{ w*t }.
    th2 <- (w=w2, t=t) (#ascii) 수식{ w*t }.

    y <- ((th1) sin) + ((th2) sin).

    보임 {
      t: t.
      y: y.
    }.
    t <- t + dt.
  }.
}.
