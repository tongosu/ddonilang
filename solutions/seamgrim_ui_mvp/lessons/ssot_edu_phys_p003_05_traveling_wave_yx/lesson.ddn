(매마디)마다 {
  // 출력은 숫자만. (x, y) 순서.

  A <- 1.
  lambda <- 4.
  pi <- 3.1415926535.
  omega <- 2.
  t0 <- 0.

  // k = 2π/λ
  k <- (pi=pi, lambda=lambda) (#ascii) 수식{ 2*pi/lambda }.

  x_min <- 0.
  x_max <- 20.
  dx <- 0.05.

  x <- x_min.

  { x <= x_max }인것 동안: {
    phase <- (k=k, x=x, omega=omega, t0=t0) (#ascii) 수식{ k*x - omega*t0 }.
    s <- (phase) sin.
    y <- (A=A, s=s) (#ascii) 수식{ A*s }.

    보임 {
      값1: x.
      값2: y.
    }.

    x <- x + dx.
  }.
}.
