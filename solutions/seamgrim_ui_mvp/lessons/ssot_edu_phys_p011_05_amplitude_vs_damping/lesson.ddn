// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  c <- 0.1.
}.

(매마디)마다 {
  // 출력은 숫자만. (c, A) 순서.
  // 설정: m=1, k=4, ω=2(자연각진동수), F0=1.

  m <- 1.
  k <- 4.
  w <- 2.
  F0 <- 1.

  c_min <- 0.1.
  c_max <- 5.
  dc <- 0.05.

  { c <= c_max }인것 일때 {
    d <- k - (m*w*w).
    p <- d * d.
    q <- (c*w) * (c*w).
    u <- p + q.
    den <- ((u) sqrt).
    A <- F0 / den.

    보임 {
      c: c.
      A: A.
    }.
    c <- c + (dc).
  }.
}.
