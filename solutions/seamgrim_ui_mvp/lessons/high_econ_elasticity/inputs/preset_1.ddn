#이름: high_econ_elasticity_variant_high_econ_elasticity
#설명: y = a x^2 + b

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 0.
}.

(매마디)마다 {
  탄력 = (#ascii1) 수식{ y = a x^2 + b }.

  a <- 0.2.
  b <- 1.

  { x <= 6 }인것 일때 {
    y <- a x^2 + b.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (0.5).
  }.
}.
