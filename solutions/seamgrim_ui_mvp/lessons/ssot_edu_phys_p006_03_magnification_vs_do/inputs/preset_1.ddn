#이름: ssot_edu_phys_p006_03_magnification_vs_do_variant_P006-03 확대율 m(d_o)
#설명: 얇은 렌즈에서 확대율 m = - d_i / d_o = - f / (d_o - f) 를 점열로 출력.

// 출력은 숫자만. (d_o, m) 순서.

f <- 10.

d_o_min <- 12.
d_o_max <- 100.
dd_o <- 2.

m_of_d_o = (#ascii1) 수식{ y = - f / (x - f) }.

(시작)할때 {
  d_o <- d_o_min.
}.

(매마디)마다 {
  { d_o <= d_o_max }인것 일때 {
    m <- - f / (d_o - f).
    보임 {
      x: d_o.
      m: m.
    }.
    d_o <- d_o + dd_o.
  }.
}.
