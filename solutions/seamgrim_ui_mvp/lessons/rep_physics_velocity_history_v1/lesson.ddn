설정 {
  제목: "속도 기록 그래프".
  설명: "이력에 쌓이는 속도 값을 그래프와 표로 관찰합니다.".
  마디수: 14.
}.

(시작)할때 {
  t <- 0.
  v <- 0.
  a <- 2.
  dt <- 0.5.
  속도이력 <- (8) 이력.만들기.
}.

(매마디)마다 {
  { t <= 6 }인것 일때 {
    v <- v + a * dt.
    속도이력 <- (속도이력, v) 이력.밀어넣기.
    최근속도 <- (속도이력) 이력.최근값.
    기록길이 <- (속도이력) 이력.길이.
    보임 {
      t: t.
      v: v.
      최근속도: 최근속도.
      기록길이: 기록길이.
    }.
    t <- t + dt.
  }.
}.

