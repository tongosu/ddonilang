#이름: ssot_edu_phys_p015_05_linear_drag_fall_t_v_variant_P015-05 선형저항 낙하 v(t)
#설명: 선형저항(공기저항∝v)에서 dv/dt = g - (b/m) v 를 Euler로 적분. (t, v) 출력.

// stateful-sim preview(auto): range sampler -> step sim
g <- 9.8.
m <- 1.
b <- 1.

dt <- 0.02.
t_max <- 5.

t <- 0.


(시작)할때 {
  ti <- 0.
  v <- 0.
}.

(매마디)마다 {
  { ti <= t_max }인것 일때 {
    보임 {
      ti: ti.
      v: v.
    }.
    
    a <- g - ((b / m) * v).
    v <- v + (a * dt).
    ti <- ti + (dt).
  }.
}.
