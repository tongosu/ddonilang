// stateful-sim preview(auto): range sampler -> step sim
g <- 9.8.
m <- 1.
b <- 1.

dt <- 0.02.
t_max <- 5.

t <- 0.


(시작)할때 {
  ti <- 0.
  v <- 0.
}.

(매마디)마다 {
  { ti <= t_max }인것 일때 {
    보임 {
      ti: ti.
      v: v.
    }.
    
    a <- g - ((b / m) * v).
    v <- v + (a * dt).
    ti <- ti + (dt).
  }.
}.
