#이름: ssot_edu_phys_p014_02_electric_potential_r_V_variant_P014-02 전위 V(r)
#설명: 점전하 주변 전위 V(r)=k/r (교육용 스케일). r=0 회피. (r,V) 출력.

k <- 1000.

r_min <- 1.
r_max <- 50.
dr <- 1.

(시작)할때 {
  r <- r_min.
}.

(매마디)마다 {
  { r <= r_max }인것 일때 {
    V <- k / r.

    보임 {
      r: r.
      V: V.
    }.

    r <- r + dr.
  }.
}.
