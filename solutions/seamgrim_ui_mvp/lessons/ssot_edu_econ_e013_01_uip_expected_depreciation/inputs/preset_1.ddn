
#기본관찰x: i_dom
#기본관찰: ds

채비 {
  i_for: 수 <- (0.03) 매김 { 범위: -0.1..0.2. 간격: 0.005. }.
  i_dom_min: 수 <- (-0.02) 매김 { 범위: -0.2..0.2. 간격: 0.005. }.
  i_dom_max: 수 <- (0.10) 매김 { 범위: -0.1..0.4. 간격: 0.005. }.
  di: 수 <- (0.002) 매김 { 범위: 0.001..0.02. 간격: 0.001. }.
}.

(시작)할때 {
  t <- 0.
  i_dom <- i_dom_min.
}.

(매마디)마다 {
  { i_dom <= i_dom_max }인것 일때 {
    ds <- i_dom - i_for.

    보임 {
      t: t.
      i_dom: i_dom.
      ds: ds.
    }.

    i_dom <- i_dom + di.
    t <- t + 1.
  }.
}.
