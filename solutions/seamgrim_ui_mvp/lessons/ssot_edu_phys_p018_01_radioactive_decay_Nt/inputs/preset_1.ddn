#이름: ssot_edu_phys_p018_01_radioactive_decay_Nt_variant_P018-01 방사성 붕괴 N(t)
#설명: N_{t+1} = N_t*(1 - lambda*dt).  (지수붕괴의 차분 근사)

// 출력은 숫자만. (t, N) 순서.

N0 <- 1000.
lambda <- 0.05.
dt <- 1.

t_max <- 100.

(시작)할때 {
  t <- 0.
  N <- N0.
}.

(매마디)마다 {
  { t <= t_max }인것 일때 {
    보임 {
      t: t.
      N: N.
    }.

    N <- N * (1 - lambda*dt).
    { N < 0 }인것 일때 {
      N <- 0.
    }.
    t <- t + dt.
  }.
}.
