// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  V <- 0.5.
}.

(매마디)마다 {
  // 출력은 숫자만. (V, P) 순서.
  // NOTE: export_graph.py는 stdout 숫자쌍을 (x,y)로 묶는다.

  n <- 1.
  R <- 8.314.
  T <- 300.

  V_min <- 0.5.
  V_max <- 5.
  dV <- 0.25.

  압력식 = (#ascii1) 수식{ y = n*R*T / x }.

  { V <= V_max }인것 일때 {
    P <- n*R*T / V.
    V <- V + (dV).
  }.
}.
