#이름: ssot_edu_phys_p013_02_isothermal_work_v_W_variant_P013-02 등온 팽창에서 누적 일 W(V) (수치적분)
#설명: W(V)=∫ P dV 를 누적합으로 근사. P(V)=k/V. (V,W) 점열 출력.

// stateful-sim preview(auto): range sampler -> step sim
k <- 100.

V_min <- 1.
V_max <- 20.
dV <- 0.1.



(시작)할때 {
  V <- V_min.
  W <- 0.
}.

(매마디)마다 {
  { V <= V_max }인것 일때 {
    P <- k / V.
    W <- W + (P * dV).
    
    보임 {
      V: V.
      W: W.
    }.
    V <- V + (dV).
  }.
}.
