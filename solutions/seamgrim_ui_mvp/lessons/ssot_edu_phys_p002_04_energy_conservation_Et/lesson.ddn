(매마디)마다 {
  // 출력은 숫자만. (t, E) 순서.
  // NOTE: y<0이면 출력하지 않고 종료한다.

  m <- 1.
  y0 <- 50.
  g <- 9.8.
  dt <- 0.05.

  t <- 0.

  반복: {
    y <- (y0=y0, g=g, t=t) (#ascii) 수식{ y0 - (g*t^2)/2 }.

    { y < 0 }인것 일때 {
      멈추기.
    }.

    v <- (g=g, t=t) (#ascii) 수식{ g*t }.
    K <- (m=m, v=v) (#ascii) 수식{ m*(v^2)/2 }.
    U <- (m=m, g=g, y=y) (#ascii) 수식{ m*g*y }.
    E <- (K=K, U=U) (#ascii) 수식{ K + U }.

    보임 {
      값1: t.
      값2: E.
    }.

    t <- t + dt.
  }.
}.
