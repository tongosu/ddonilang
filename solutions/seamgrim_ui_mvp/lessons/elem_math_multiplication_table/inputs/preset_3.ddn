#기본관찰x: n
#기본관찰: 곱

채비 {
  단: 수 <- (3.0) 매김 { 범위: 1..19. 간격: 1. }.
  시작수: 수 <- (1.0) 매김 { 범위: 1..30. 간격: 1. }.
  끝수: 수 <- (12.0) 매김 { 범위: 1..50. 간격: 1. }.
  최대마디: 수 <- (20.0) 매김 { 범위: 5..500. 간격: 1. }.
}.

(시작)할때 {
  t <- 0.
  n <- 시작수.
}.

(매마디)마다 {
  { t < 최대마디 }인것 일때 {
    곱 <- 단 * n.
    이전곱 <- 단 * (n - 1).
    증가량 <- 곱 - 이전곱.

    보임 {
      t: t.
      단: 단.
      n: n.
      곱: 곱.
      증가량: 증가량.
    }.

    n <- n + 1.
    { n > 끝수 }인것 일때 { n <- 시작수. }.
    t <- t + 1.
  }.
}.
