#이름: 월별 강수량
#설명: 월별 패턴

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 1.
}.

(매마디)마다 {
  A <- 5.
  w <- 0.6.

  x_min <- 1.
  x_max <- 14.
  dx <- 1.

  { x <= x_max }인것 일때 {
    angle <- w * x.
    s <- (angle) sin.
    y <- A * s.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (dx).
  }.
}.
