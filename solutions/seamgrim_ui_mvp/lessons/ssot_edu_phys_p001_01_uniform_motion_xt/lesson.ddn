(매마디)마다 {
  // NOTE:
  // - export_graph.py는 teul-cli 기본 1마디 실행이므로, 이 파일은 '한 번 실행'으로 점열을 모두 출력한다.
  // - 출력은 숫자만(로그/문자 출력 금지). (t, x) 순서로 출력된다.

  x0 <- 0.
  v <- 2.
  dt <- 0.1.
  t_max <- 10.

  t <- 0.

  { t <= t_max }인것 동안: {
    x <- (x0=x0, v=v, t=t) (#ascii) 수식{ x0 + v*t }.

    // (t, x)
    보임 {
      값1: t.
      값2: x.
    }.

    t <- t + dt.
  }.
}.
