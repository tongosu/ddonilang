
#기본관찰x: n
#기본관찰: 항

채비 {
  첫항: 수 <- (1.0) 매김 { 범위: -100..100. 간격: 1. }.
  공차: 수 <- (4.0) 매김 { 범위: -20..20. 간격: 1. }.
  최대항수: 수 <- (6.0) 매김 { 범위: 5..500. 간격: 1. }.
}.

(시작)할때 {
  n <- 1.
  누적합 <- 0.
}.

(매마디)마다 {
  { n <= 최대항수 }인것 일때 {
    항 <- 첫항 + (n - 1) * 공차.
    누적합 <- 누적합 + 항.
    평균 <- 누적합 / n.

    보임 {
      n: n.
      항: 항.
      누적합: 누적합.
      평균: 평균.
    }.

    n <- n + 1.
  }.
}.
