#이름: ssot_edu_phys_p018_03_debroglie_lambda_of_p_variant_P018-03 드브로이 파장 λ(p)=h/p
#설명: λ = h/p.  p가 커질수록 파장은 작아진다(반비례).

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  p <- 0.1.
}.

(매마디)마다 {
  // 출력은 숫자만. (p, λ) 순서.

  h <- 1.0.

  p_min <- 0.1.
  p_max <- 5.0.
  dp <- 0.05.

  { p <= p_max }인것 일때 {
    lam <- h / p.

    보임 {
      p: p.
      lam: lam.
    }.
    p <- p + (dp).
  }.
}.
