
#기본관찰x: p
#기본관찰: qs

채비 {
  c: 수 <- (-25.0) 매김 { 범위: -80..80. 간격: 5. }.
  d: 수 <- (1.8) 매김 { 범위: 0.2..5. 간격: 0.1. }.
  p_min: 수 <- (0.0) 매김 { 범위: 0..100. 간격: 1. }.
  p_max: 수 <- (80.0) 매김 { 범위: 10..200. 간격: 1. }.
  dp: 수 <- (1.0) 매김 { 범위: 0.5..10. 간격: 0.5. }.
}.

(시작)할때 {
  t <- 0.
  p <- p_min.
}.

(매마디)마다 {
  { p <= p_max }인것 일때 {
    qs <- c + (d * p).
    { qs < 0 }인것 일때 { qs <- 0. }.

    보임 {
      t: t.
      p: p.
      qs: qs.
    }.

    p <- p + dp.
    t <- t + 1.
  }.
}.
