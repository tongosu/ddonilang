#이름: ssot_edu_phys_p013_01_isothermal_pv_v_p_variant_P013-01 등온 과정 PV 곡선 P(V)=k/V
#설명: 등온 과정에서 P(V)=k/V. (V,P) 점열 출력.

k <- 100.

V_min <- 1.
V_max <- 20.
dV <- 0.1.

(시작)할때 {
  V <- V_min.
}.

(매마디)마다 {
  { V <= V_max }인것 일때 {
    P <- k / V.

    보임 {
      V: V.
      P: P.
    }.

    V <- V + dV.
  }.
}.
