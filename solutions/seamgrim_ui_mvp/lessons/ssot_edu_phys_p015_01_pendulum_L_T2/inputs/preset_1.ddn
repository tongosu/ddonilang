#이름: ssot_edu_phys_p015_01_pendulum_L_T2_variant_P015-01 단진자 주기제곱 T²(L)
#설명: 소각근사 단진자 주기 T = 2π√(L/g). 제곱하면 T² = (4π²/g)·L (선형). (L, T²) 출력.

pi <- 3.141592.
g <- 9.8.

L_min <- 0.
L_max <- 4.
dL <- 0.05.

coef <- (4 * pi * pi) / g.  # T^2 = coef * L

(시작)할때 {
  L <- L_min.
}.

(매마디)마다 {
  { L <= L_max }인것 일때 {
    T2 <- coef * L.

    보임 {
      L: L.
      T2: T2.
    }.
    L <- L + dL.
  }.
}.
