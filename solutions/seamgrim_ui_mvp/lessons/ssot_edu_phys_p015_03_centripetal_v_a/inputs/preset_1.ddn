#이름: ssot_edu_phys_p015_03_centripetal_v_a_variant_P015-03 구심가속도 a(v)=v²/r
#설명: 원운동 구심가속도 a=v²/r. r 고정 시 a는 v에 대해 제곱비례. (v, a) 출력.

r <- 10.

v_min <- 0.
v_max <- 50.
dv <- 0.5.

(시작)할때 {
  v <- v_min.
}.

(매마디)마다 {
  { v <= v_max }인것 일때 {
    a <- (v * v) / r.

    보임 {
      v: v.
      a: a.
    }.
    v <- v + dv.
  }.
}.
