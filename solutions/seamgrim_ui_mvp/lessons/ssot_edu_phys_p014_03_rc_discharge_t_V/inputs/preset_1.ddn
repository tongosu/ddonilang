#이름: ssot_edu_phys_p014_03_rc_discharge_t_V_variant_P014-03 RC 방전 V(t)
#설명: RC 방전: dV/dt = -(1/(R*C)) V 를 이산 업데이트로 근사. V <- V - (dt/(R*C))*V. (t,V) 출력.

// stateful-sim preview(auto): range sampler -> step sim
R <- 1.
C <- 1.

dt <- 0.05.
t_max <- 5.



(시작)할때 {
  t <- 0.
  V <- 1.
}.

(매마디)마다 {
  { t <= t_max }인것 일때 {
    보임 {
      t: t.
      V: V.
    }.
    
    V <- V - ((dt / (R * C)) * V).
    { V < 0 }인것 일때 {
      V <- 0.
    }.
    t <- t + (dt).
  }.
}.
