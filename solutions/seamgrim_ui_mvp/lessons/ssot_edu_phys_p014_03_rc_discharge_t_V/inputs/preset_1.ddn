
// stateful-sim preview(auto): range sampler -> step sim
R <- 1.
C <- 1.

dt <- 0.05.
t_max <- 5.



(시작)할때 {
  t <- 0.
  V <- 1.
}.

(매마디)마다 {
  { t <= t_max }인것 일때 {
    보임 {
      t: t.
      V: V.
    }.
    
    V <- V - ((dt / (R * C)) * V).
    { V < 0 }인것 일때 {
      V <- 0.
    }.
    t <- t + (dt).
  }.
}.
