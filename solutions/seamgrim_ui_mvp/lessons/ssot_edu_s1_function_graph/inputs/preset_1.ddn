채비 {
  a:수 <- (2.2) 매김 { 범위: -5..5. 간격: 0.1. }.
  b:수 <- (-3.0) 매김 { 범위: -10..10. 간격: 0.1. }.
  x_min:수 <- (-5) 매김 { 범위: -20..0. 간격: 0.5. }.
  x_max:수 <- (5) 매김 { 범위: 0..20. 간격: 0.5. }.
  dx:수 <- (0.25) 매김 { 범위: 0.05..2. 간격: 0.05. }.
}.

(매마디)마다 {
  a <- 2.2.
  b <- -3.0.
  x_min <- -5.
  x_max <- 5.
  dx <- 0.25.

  x <- x_min.
  { x <= x_max }인것 동안: {
    y <- a * x + b.
    x <- x + dx.
  }.
}.
