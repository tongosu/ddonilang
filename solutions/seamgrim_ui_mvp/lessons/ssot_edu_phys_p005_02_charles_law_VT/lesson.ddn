// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  T <- 250.
}.

(매마디)마다 {
  // 출력은 숫자만. (T, V) 순서.
  // NOTE: export_graph.py는 stdout 숫자쌍을 (x,y)로 묶는다.

  n <- 1.
  R <- 8.314.
  P <- 101.325.

  T_min <- 250.
  T_max <- 400.
  dT <- 10.

  부피식 = (#ascii1) 수식{ y = n*R*x / P }.

  { T <= T_max }인것 일때 {
    V <- n*R*T / P.
    보임 {
      T: T.
      V: V.
    }.
    T <- T + (dT).
  }.
}.
