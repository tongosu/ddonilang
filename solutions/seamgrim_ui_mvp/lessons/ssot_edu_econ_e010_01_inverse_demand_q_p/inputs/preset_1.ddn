
#기본관찰x: Q
#기본관찰: P

채비 {
  a: 수 <- (110.0) 매김 { 범위: 20..200. 간격: 10. }.
  b: 수 <- (1.2) 매김 { 범위: 0.2..5. 간격: 0.1. }.
  Q_min: 수 <- (0.0) 매김 { 범위: 0..200. 간격: 1. }.
  Q_max: 수 <- (140.0) 매김 { 범위: 20..300. 간격: 1. }.
  dQ: 수 <- (1.0) 매김 { 범위: 0.5..10. 간격: 0.5. }.
}.

(시작)할때 {
  t <- 0.
  Q <- Q_min.
}.

(매마디)마다 {
  { Q <= Q_max }인것 일때 {
    P <- a - (b * Q).
    { P < 0 }인것 일때 { P <- 0. }.

    보임 {
      t: t.
      Q: Q.
      P: P.
    }.

    Q <- Q + dQ.
    t <- t + 1.
  }.
}.
