(매마디)마다 {
  // 출력은 숫자만. (V, I_total) 순서.
  // NOTE: 병렬 저항에서 '같은 전압'이 걸린다는 점을 활용한다.

  R1 <- 10.
  R2 <- 20.

  V_min <- 0.
  V_max <- 10.
  dV <- 0.25.

  V <- V_min.

  { V <= V_max }인것 동안: {
    I_total <- (V=V, R1=R1, R2=R2) (#ascii) 수식{ V/R1 + V/R2 }.

    보임 {
      값1: V.
      값2: I_total.
    }.

    V <- V + dV.
  }.
}.
