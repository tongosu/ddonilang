(매마디)마다 {
  // 출력은 숫자만. (t, Vc) 순서.
  // NOTE: 지수해를 쓰지 않고 오일러(Euler) 적분으로 '충전 곡선'을 만든다.

  Vin <- 5.
  R <- 10.
  C <- 0.1.        // R*C = 1
  dt <- 0.01.
  t_max <- 5.

  t <- 0.
  Vc <- 0.

  { t <= t_max }인것 동안: {
    // (t, Vc)

    dVc <- (Vin=Vin, Vc=Vc, R=R, C=C) (#ascii) 수식{ (Vin - Vc) / (R*C) }.
    Vc <- (Vc=Vc, dVc=dVc, dt=dt) (#ascii) 수식{ Vc + dVc*dt }.

    t <- t + dt.
  }.
}.
