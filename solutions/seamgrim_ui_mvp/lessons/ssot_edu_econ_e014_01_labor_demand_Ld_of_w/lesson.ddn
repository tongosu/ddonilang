#기본관찰x: w
#기본관찰: Ld

채비 {
  a: 수 <- (100.0) 매김 { 범위: 20..300. 간격: 5. }.
  b: 수 <- (2.0) 매김 { 범위: 0.1..8. 간격: 0.1. }.
  w_min: 수 <- (0.0) 매김 { 범위: 0..120. 간격: 1. }.
  w_max: 수 <- (60.0) 매김 { 범위: 10..200. 간격: 1. }.
  dw: 수 <- (1.0) 매김 { 범위: 0.5..10. 간격: 0.5. }.
}.

(시작)할때 {
  t <- 0.
  w <- w_min.
}.

(매마디)마다 {
  { w <= w_max }인것 일때 {
    Ld <- a - (b * w).
    { Ld < 0 }인것 일때 { Ld <- 0. }.

    보임 {
      t: t.
      w: w.
      Ld: Ld.
    }.

    w <- w + dw.
    t <- t + 1.
  }.
}.
