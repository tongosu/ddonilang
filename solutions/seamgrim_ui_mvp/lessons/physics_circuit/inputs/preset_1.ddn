#이름: physics_circuit_variant_physics_circuit
#설명: 간단 회로 구조(노드-간선)

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 0.
}.

(매마디)마다 {
  전압 = (#ascii1) 수식{ y = a x + b }.

  a <- 1.
  b <- 0.

  { x <= 3 }인것 일때 {
    y <- a x + b.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (1).
  }.
}.
