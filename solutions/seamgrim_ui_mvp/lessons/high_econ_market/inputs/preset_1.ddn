#이름: high_econ_market_variant_high_econ_market
#설명: y = a x + b

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  x <- 0.
}.

(매마디)마다 {
  수요 = (#ascii1) 수식{ y = a x + b }.

  a <- -0.8.
  b <- 10.

  { x <= 10 }인것 일때 {
    y <- a x + b.
    보임 {
      x: x.
      y: y.
    }.
    x <- x + (1).
  }.
}.
