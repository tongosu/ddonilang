// 출력은 숫자만. (d_o, d_i) 순서.

f <- 10.

d_o_min <- 12.
d_o_max <- 100.
dd_o <- 2.

d_i_of_d_o = (#ascii1) 수식{ y = (f * x) / (x - f) }.

(시작)할때 {
  d_o <- d_o_min.
}.

(매마디)마다 {
  { d_o <= d_o_max }인것 일때 {
    d_i <- (f * d_o) / (d_o - f).
    보임 {
      x: d_o.
      d_i: d_i.
    }.
    d_o <- d_o + dd_o.
  }.
}.
