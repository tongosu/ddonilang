
#기본관찰x: X
#기본관찰: Y

채비 {
  A: 수 <- (100.0) 매김 { 범위: 20..200. 간격: 5. }.
  b: 수 <- (1.5) 매김 { 범위: 0.1..5. 간격: 0.1. }.
  X_min: 수 <- (0.0) 매김 { 범위: 0..200. 간격: 1. }.
  X_max: 수 <- (60.0) 매김 { 범위: 10..300. 간격: 1. }.
  dX: 수 <- (1.0) 매김 { 범위: 0.5..10. 간격: 0.5. }.
}.

(시작)할때 {
  t <- 0.
  X <- X_min.
}.

(매마디)마다 {
  { X <= X_max }인것 일때 {
    Y <- A - (b * X).
    { Y < 0 }인것 일때 { Y <- 0. }.

    보임 {
      t: t.
      X: X.
      Y: Y.
    }.

    X <- X + dX.
    t <- t + 1.
  }.
}.
