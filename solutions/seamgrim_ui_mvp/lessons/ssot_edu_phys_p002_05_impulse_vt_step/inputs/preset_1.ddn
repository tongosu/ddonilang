(매마디)마다 {
  // 출력은 숫자만. (t, v) 순서.

  v0 <- 0.
  a <- 3.
  t_push <- 2.
  t_max <- 6.
  dt <- 0.05.

  t <- 0.

  { t <= t_max }인것 동안: {
    t <= t_push 일때 {
      v <- (v0=v0, a=a, t=t) (#ascii) 수식{ v0 + a*t }.
    } 아니면 {
      v <- (v0=v0, a=a, tp=t_push) (#ascii) 수식{ v0 + a*tp }.
    }.

    t <- t + dt.
  }.
}.
