#이름: college_physics_orbit_variant_college_physics_orbit
#설명: 단순 궤적 근사

// stateful-sim preview(auto): range sampler -> step sim

(시작)할때 {
  t <- 0.
}.

(매마디)마다 {
  수평 = (#ascii1) 수식{ x = v t }.
  수직 = (#ascii1) 수식{ y = u t - 0.5 g t^2 }.

  v <- 3.
  u <- 5.
  g <- 1.2.

  { t <= 4 }인것 일때 {
    x <- v t.
    y <- u t - 0.5 g t^2.
    보임 {
      x: x.
      y: y.
    }.
    t <- t + (0.4).
  }.
}.
