#기본관찰x: a
#기본관찰: p별

채비 {
  b: 수 <- (2.0) 매김 { 범위: 0.2..5. 간격: 0.1. }.
  c: 수 <- (-20.0) 매김 { 범위: -80..80. 간격: 5. }.
  d: 수 <- (1.5) 매김 { 범위: 0.2..5. 간격: 0.1. }.
  a_min: 수 <- (60.0) 매김 { 범위: 10..200. 간격: 2. }.
  a_max: 수 <- (140.0) 매김 { 범위: 20..260. 간격: 2. }.
  da: 수 <- (2.0) 매김 { 범위: 0.5..20. 간격: 0.5. }.
}.

(시작)할때 {
  t <- 0.
  a <- a_min.
}.

(매마디)마다 {
  { a <= a_max }인것 일때 {
    분모 <- b + d.
    p별 <- 0.
    q별 <- 0.
    { 분모 > 0 }인것 일때 {
      p별 <- (a - c) / 분모.
      { p별 < 0 }인것 일때 { p별 <- 0. }.
      q별 <- c + (d * p별).
      { q별 < 0 }인것 일때 { q별 <- 0. }.
    }.

    보임 {
      t: t.
      a: a.
      p별: p별.
      q별: q별.
    }.

    a <- a + da.
    t <- t + 1.
  }.
}.
