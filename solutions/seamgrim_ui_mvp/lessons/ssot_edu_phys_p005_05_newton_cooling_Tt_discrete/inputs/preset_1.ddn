// stateful-sim preview(auto): range sampler -> step sim
// 출력은 숫자만. (t, T) 순서.
// NOTE: export_graph.py는 stdout 숫자쌍을 (x,y)로 묶는다.

// 이 수업은 '지수함수(exp)'를 직접 쓰지 않고,
// 작은 dt로 반복 업데이트해서 냉각 곡선을 만든다(이산 근사).

Tenv <- 20.
k <- 0.15.
dt <- 0.5.
t_max <- 30.

(시작)할때 {
  t <- 0.
  T <- 90.
}.

(매마디)마다 {
  { t <= t_max }인것 일때 {
    
    T <- T - k * (T - Tenv) * dt.
    t <- t + (dt).
  }.
}.
