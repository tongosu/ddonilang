(매마디)마다 {
  // 출력은 숫자만. (t, y) 순서.
  // NOTE: y<0(지면 아래)면 출력하지 않고 종료한다.

  y0 <- 50.
  g <- 9.8.
  dt <- 0.05.

  t <- 0.

  반복: {
    y <- (y0=y0, g=g, t=t) (#ascii) 수식{ y0 - (g*t^2)/2 }.

    { y < 0 }인것 일때 {
      멈추기.
    }.

    // (t, y)
    보임 {
      값1: t.
      값2: y.
    }.

    t <- t + dt.
  }.
}.
