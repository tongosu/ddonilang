빈 <- ".".
막힘 <- ("X") 차림.
격 <- (4, 6, 빈) 격자.만들기.
가방 <- (0, ("I", "O") 차림) 무작위가방.만들기.
상태0 <- () 격자게임상태.초기화.
진행 <- (상태0, "진행") 격자게임상태.바꾸기.
점 <- () 격자게임점수.초기화.
티 <- ("T") 테트로미노.만들기.
낙 <- (티, 0, 1) 낙하조각.만들기.
세션 <- (격, 가방, 진행, 점, 낙) 격자게임세션.만들기.
회전 <- (낙, 격, 막힘, "오른쪽") 격자게임.회전시도.
유령 <- (세션, 막힘) 격자게임보기.유령조각.

