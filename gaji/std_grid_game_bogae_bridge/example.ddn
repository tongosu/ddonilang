빈 <- ".".
격 <- (4, 4, 빈) 격자.만들기.
가방 <- (0, ("O", "I") 차림) 무작위가방.만들기.
상태 <- () 격자게임상태.초기화.
점 <- () 격자게임점수.초기화.
오 <- ("O") 테트로미노.만들기.
낙 <- (오, 1, 0) 낙하조각.만들기.
세션 <- (격, 가방, 상태, 점, 낙) 격자게임세션.만들기.
크기 <- (세션, 8) 격자게임보기.보개크기.

보개_그림판_가로 <- 크기.가로.
보개_그림판_세로 <- 크기.세로.
보개_바탕색 <- "#000000ff".
보개_그림판_목록 <- (세션, 빈, "O", 8) 격자게임보기.보개목록.

보개로 그려.

