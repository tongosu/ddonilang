    },
    {
      "surface": "\\역빗금",
      "reason": "same_meaning_alias_and_prefix_collision_risk"
    },
    {
      "surface": "\\줄{...}",
      "reason": "conflicts_with_text_escape_줄; use \\행제어{...}"
    },
