    {"from": "\\반전", "to": "\\스타일{반전}", "mode": "diagnostic_fixit_only"},
    {"from": "\\반전끝", "to": "\\스타일{반전끔} or \\되돌림", "mode": "diagnostic_fixit_only"}
  ],
  "template_braced_command_policy": {
    "literal_brace": "{{/}}",
    "backslash_brace_surface": "excluded",
    "placeholder_scanner_ignores_registered_braced_command_payload": true,
    "examples": [
      {"template": "글무늬{\"\\문자{알파} = {값}\"}", "placeholders": ["값"]},
      {"template": "글무늬{\"\\색{빨강}경고 {이름}\\되돌림\"}", "placeholders": ["이름"]},
      {"template": "글무늬{\"\\커서{행=1,칸=1}{문장}\"}", "placeholders": ["문장"]}
    ]
  },
  "universal_character_command": {
    "surface": "\\문자{...}",
    "command": "문자",
    "argument_policy": "unicode_scalar_or_registered_alias",
    "coverage": "all_unicode_scalar_values",
    "examples": ["\\문자{알파}", "\\문자{오른화살}", "\\문자{U+AC00}", "\\문자{U+1F600}"]
  },
