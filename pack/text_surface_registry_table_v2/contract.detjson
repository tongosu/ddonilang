  "policy": {
    "min_direct_shortcuts": 400,
    "min_braced_aliases": 900,
    "prefix_free_direct_commands": true,
    "no_compat_shim": true,
    "unknown_backslash_command": "error",
    "unicode_fallback": "\\문자{U+XXXX}",
    "unicode_fallback_last_resort": true,
    "raw_ansi_escape_output": false,
    "removed_surface_migration": "diagnostic_fixit_only",
    "runtime_compat_shim_for_removed_surface": false,
    "template_scanner_ignores_registered_braced_command_payload": true,
    "implementation_change_allowed_in_this_pack": false
