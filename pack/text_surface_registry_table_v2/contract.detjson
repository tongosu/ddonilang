  "removed_surface_fixits": [
    {"from": "\\따옴", "to": "\\\"", "mode": "diagnostic_fixit_only"},
    {"from": "\\역빗금", "to": "\\\\", "mode": "diagnostic_fixit_only"},
    {"from": "\\굵게", "to": "\\스타일{굵게}", "mode": "diagnostic_fixit_only"},
