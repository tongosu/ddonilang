#기본관찰x: t
#기본관찰: y
채비 {
  a: 수 <- (1) 매김 {
    범위: 1..5.
    간격: 1.
  }.
  b: 수 <- (1) 매김 {
    범위: 1..10.
    간격: 1.
  }.
  dt: 수 <- (1) 매김 {
    범위: 1..5.
    간격: 1.
  }.
  n_max: 수 <- (10) 매김 {
    범위: 5..50.
    간격: 5.
  }.
  t: 수 <- 0.
  y: 수 <- 0.
}.

(시작)할때 {
  a <- 1.
  b <- 1.
  dt <- 1.
  n_max <- 10.
  t <- 0.
  y <- 0.
}.

(매마디)마다 {
  { t <= n_max }인것 일때 {
    y <- a * t + b.
    t <- t + dt.
  }.
  t 보여주기.
  y 보여주기.
}.
