rel <- ((#ascii) 수식{(x + 1)^2}, (#ascii) 수식{x^2 + 2*x + 1}) 잇기.
증거1 <- ((관계=rel)) 증명하기.

rel1 <- ((#ascii) 수식{x + y}, (#ascii) 수식{5}) 잇기.
rel2 <- ((#ascii) 수식{x - y}, (#ascii) 수식{1}) 잇기.
rels <- (rel1, rel2) 차림.
해 <- (rels) 방정식풀기.
증거2 <- ((관계=rels, 해=해.해)) 증명하기.

검사 <- 세움{
  (#ascii) 수식{x + y} =:= (#ascii) 수식{5}
}.
판정 <- (세움=검사, 값들=(x=("3") 큰바른수, y=("2") 큰바른수)) 살피기.

증거1.검증 보여주기.
증거1.종류 보여주기.
증거2.검증 보여주기.
증거2.종류 보여주기.
판정 보여주기.
