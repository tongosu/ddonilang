q <- ((#ascii) 수식{x^2 - 4*x + 4}) =:= ((#ascii) 수식{0}).
첫째결과 <- (q) 방정식풀기.

rel1 <- ((#ascii) 수식{x + y}) =:= ((#ascii) 수식{5}).
rel2 <- ((#ascii) 수식{x - y}) =:= ((#ascii) 수식{1}).
s <- (rel1, rel2) 차림.
둘째결과 <- (s) 방정식풀기.

u <- ((#ascii) 수식{x^2 - 2}) =:= ((#ascii) 수식{0}).
셋째결과 <- (u) 방정식풀기.

첫째결과 보여주기.
둘째결과 보여주기.
셋째결과 보여주기.
