(경험치:수) 경험치_획득:알림씨 = {
}.

(레벨:수) 레벨업:알림씨 = {
}.

영웅:임자 = {
  제.경험치 <- 0.
  제.레벨 <- 1.
  제.레벨업_수 <- 0.
  제.마지막_알림 <- "".

  (알림 알림.이름 == "경험치_획득")인 알림을 받으면 {
    제.경험치 <- 제.경험치 + 알림.정보.경험치.
  }.

  (정보 정보.경험치 >= 100)인 경험치_획득을 받으면 {
    제.레벨 <- 제.레벨 + 1.
    (레벨:제.레벨) 레벨업 ~~> 제.
  }.

  레벨업을 받으면 {
    제.레벨업_수 <- 제.레벨업_수 + 1.
    제.마지막_알림 <- "레벨업".
  }.
}.

(시작)할때 {
  (경험치:120) 경험치_획득 ~~> 영웅.
  영웅.경험치 보여주기.
  영웅.레벨 보여주기.
  영웅.레벨업_수 보여주기.
  영웅.마지막_알림 보여주기.
}.
