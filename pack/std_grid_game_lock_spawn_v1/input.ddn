빈 <- ".".
격 <- (4, 4, 빈) 격자.만들기.
가방 <- (0, ("O", "I") 차림) 무작위가방.만들기.
상태0 <- () 격자게임상태.초기화.
진행상태 <- (상태0, "진행") 격자게임상태.바꾸기.
점 <- () 격자게임점수.초기화.
오 <- ("O") 테트로미노.만들기.
낙 <- (오, 1, 2) 낙하조각.만들기.
세션 <- (격, 가방, 진행상태, 점, 낙) 격자게임세션.만들기.
조작맵 <- () 입력사상.만들기.
틱 <- (세션, 조작맵) 격자게임.한틱.
고정 <- 틱.고정됐나.
지운수 <- 틱.지운줄수.
다음세션 <- 틱.세션.
다음격 <- (다음세션) 격자게임세션.격자.
잠긴값 <- (다음격, 1, 2) 격자.값.
다음낙 <- (다음세션) 격자게임세션.낙하조각.
다음위치 <- (다음낙) 낙하조각.위치.

고정 보여주기.
지운수 보여주기.
잠긴값 보여주기.
다음위치 보여주기.

