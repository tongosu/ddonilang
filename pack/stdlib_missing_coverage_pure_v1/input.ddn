합친글 <- ("안녕", "또니") 합치기.
숫자 <- ("12.5") 숫자로.
숫자실패 <- ("abc") 숫자로.
글값 <- (123) 글로.

목록 <- ["a", "bb", "ccc"].
제거됨 <- (목록, 1) 제거.

제곱근 <- (9) sqrt.
거듭제곱 <- (2, 5) powi.

수식값 <- (#ascii) 수식{ x + 1 }.
풀기결과 <- (수식값, (x=6)) 풀기.

([1, 2, 3], {x| x}) 각각돌며.

합친글 보여주기.
숫자 보여주기.
숫자실패 보여주기.
글값 보여주기.
제거됨 보여주기.
제곱근 보여주기.
거듭제곱 보여주기.
풀기결과 보여주기.
