채비: {
  x:수 <- 0.
  r:수 <- 0.46.
  fill:글 <- "#22c55e".
}.

(매마디)마다 {
  left <- ("left") 눌렸나.
  right <- ("right") 눌렸나.
  spin <- ("up") 막눌렸나.

  x <- 0.
  r <- 0.46.
  fill <- "#22c55e".

  { left }인것 일때 { x <- -1. }.
  { right }인것 일때 { x <- 1. }.
  { spin }인것 일때 {
    r <- 0.72.
    fill <- "#f97316".
  }.

  dot <- ("kind", "circle", "x", x, "y", 0, "r", r, "fill", fill, "stroke", "#166534", "width", 0.06) 짝맞춤.
  보개_그림판_목록 <- (dot) 차림.
}.
