x0 <- 1.
v0 <- 0.
dt <- 0.25.

a0 <- 0 - x0.
v1 <- (v0, a0, dt) 적분.오일러.
x1 <- (x0, v0, dt) 적분.오일러.

a1 <- 0 - x1.
v2 <- (v1, a1, dt) 적분.오일러.
x2 <- (x1, v1, dt) 적분.오일러.

쌍1 <- (x0, v0, a0, dt) 적분.반암시적오일러.
쌍1x <- (쌍1, 0) 차림.값.
쌍1v <- (쌍1, 1) 차림.값.

x0 보여주기.
v0 보여주기.
x1 보여주기.
v1 보여주기.
x2 보여주기.
v2 보여주기.
쌍1x 보여주기.
쌍1v 보여주기.

