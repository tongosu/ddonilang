빈칸 <- ".".
격 <- (4, 3, 빈칸) 격자.만들기.
입력 <- () 입력사상.만들기.
방향 <- (입력) 입력사상.방향.
조각 <- (((0, 0) 차림, (1, 0) 차림, (0, 1) 차림) 차림) 블록조각.만들기.
배치 <- (조각, 1, 1) 블록조각.이동.
고정 <- (배치, 격, "P") 블록조각.고정.
확인 <- (고정, 2, 1) 격자.값.
가방 <- (0, ("I", "O", "T") 차림) 무작위가방.만들기.
뽑 <- (가방) 무작위가방.꺼내기.
뽑값 <- 뽑.값.
상태0 <- () 격자게임상태.초기화.
진행 <- (상태0, "진행") 격자게임상태.바꾸기.
멈춤 <- (진행) 격자게임상태.멈춤.
재개 <- (멈춤) 격자게임상태.재개.
상태명 <- (재개) 격자게임상태.상태.
틱 <- (재개) 격자게임상태.틱.

방향 보여주기.
확인 보여주기.
뽑값 보여주기.
상태명 보여주기.
틱 보여주기.

