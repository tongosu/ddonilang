길 <- ".".
벽 <- "#".
격0 <- (4, 3, 길) 격자.만들기.
격1 <- (격0, 1, 1, 벽) 격자.바꾼값.
격2 <- (격1, 3, 0, 벽) 격자.바꾼값.

안쪽 <- (격2, 0, 0) 격자.안인가.
밖 <- (격2, 4, 0) 격자.안인가.
길막힘 <- (격2, 0, 0, (벽) 차림) 격자.막혔나.
벽막힘 <- (격2, 1, 1, (벽) 차림) 격자.막혔나.
밖막힘 <- (격2, -1, 0, (벽) 차림) 격자.막혔나.

안쪽 보여주기.
밖 보여주기.
길막힘 보여주기.
벽막힘 보여주기.
밖막힘 보여주기.
