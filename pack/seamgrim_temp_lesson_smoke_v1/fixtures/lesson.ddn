채비: {
  T0:수 <- 80.
  b:수 <- 4.
}.

(매마디)마다 {
  값목록 <- (0, 2, 1) 범위.
  (tick) 값목록에 대해: {
    temp_c <- T0 - b * tick.
    섭씨안내 <- (temp=273.15@K + temp_c * 1@K) 글무늬{"{temp|@.1C}"}.
    화씨안내 <- (temp=273.15@K + temp_c * 1@K) 글무늬{"{temp|@.1F}"}.
    보임 {
      t: tick.
      celsius: 섭씨안내.
      fahrenheit: 화씨안내.
    }.
  }.
}.
