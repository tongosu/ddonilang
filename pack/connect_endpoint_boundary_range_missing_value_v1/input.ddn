사상1 <- (변수="ep_001", 경로="전지.양극.전압").
사상2 <- (변수="ep_002", 경로="전구.왼핀.전압").
값1 <- (변수="ep_001", 경로="전지.양극.전압", 값=5).
원복 <- (__이음관계종류="endpoint_solve_result", 풀이결과종류="부분성공", 값들=[값1], 누락변수들=["ep_002"], 변수사상=[사상1, 사상2], 원래풀이="부분풀이").
범위 <- (경로="전구.왼핀.전압", 최소=0, 최대=10).
범위들 <- [범위].
검사 <- (원복, 범위들) 이음관계.범위검사.
위반 <- (검사.위반들, 0) 차림.값.
검사.__이음관계종류 보여주기.
검사.검사결과 보여주기.
검사.위반개수 보여주기.
위반.이유 보여주기.
위반.경로 보여주기.
위반.하한 보여주기.
위반.상한 보여주기.
