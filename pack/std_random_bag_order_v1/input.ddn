가방0 <- (0, ("I", "O", "T") 차림) 무작위가방.만들기.
뽑1 <- (가방0) 무작위가방.꺼내기.
값1 <- 뽑1.값.
가방1 <- 뽑1.가방.
뽑2 <- (가방1) 무작위가방.꺼내기.
값2 <- 뽑2.값.
가방2 <- 뽑2.가방.
뽑3 <- (가방2) 무작위가방.꺼내기.
값3 <- 뽑3.값.
가방3 <- 뽑3.가방.
빈가 <- (가방3) 무작위가방.비었나.
뽑4 <- (가방3) 무작위가방.꺼내기.
값4 <- 뽑4.값.
남은4 <- (뽑4.가방) 무작위가방.남은것.

값1 보여주기.
값2 보여주기.
값3 보여주기.
빈가 보여주기.
값4 보여주기.
남은4 보여주기.

