빈칸 <- ".".
벽 <- "#".
격0 <- (2, 2, 빈칸) 격자.만들기.
격1 <- (격0, 1, 0, 벽) 격자.바꾼값.
칸 <- (격1, 1, 0) 격자.값.
막힘 <- (격1, 1, 0, (벽) 차림) 격자.막혔나.
사상 <- () 입력사상.만들기.
방향 <- (사상) 입력사상.방향.
오른쪽 <- (사상, "오른쪽") 입력사상.동작.
경로 <- (격1, 0, 0, 0, 1, (벽) 차림) 격자.길찾기.
다음위치 <- (10, 2, 3) 물리1d.위치갱신.
칸 보여주기.
막힘 보여주기.
방향 보여주기.
오른쪽 보여주기.
경로 보여주기.
다음위치 보여주기.
