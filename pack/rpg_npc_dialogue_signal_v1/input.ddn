(이름:글) 대화_시작:알림씨 = {
}.

npc_대화:임자 = {
  제.방문_횟수 <- 0.
  제.마지막_대사 <- "".

  (알림 알림.이름 == "대화_시작")인 알림을 받으면 {
    제.방문_횟수 <- 제.방문_횟수 + 1.
    제.마지막_대사 <- (name=알림.정보.이름, visit=제.방문_횟수) 글무늬{"안녕 {name} 방문={visit}"}.
  }.
}.

(시작)할때 {
  (이름:"용사") 대화_시작 ~~> npc_대화.
  (이름:"용사") 대화_시작 ~~> npc_대화.
  npc_대화.방문_횟수 보여주기.
  npc_대화.마지막_대사 보여주기.
}.
