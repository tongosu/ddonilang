f <- (#ascii) 수식{x + x + 2}.
g <- (f) 정리하기.
h <- ((#ascii) 수식{(x + 1)^2}) 전개하기.
i <- ((#ascii) 수식{x^2 - 1}) 인수분해하기.
d <- ((#ascii) 수식{x^3 + 2*x}, "x") 미분하기.
a <- ((#ascii) 수식{2*x}, "x") 적분하기.
ok <- ((#ascii) 수식{(x + 1)^2}, (#ascii) 수식{x^2 + 2*x + 1}) 동치인가.
g 보여주기.
h 보여주기.
i 보여주기.
d 보여주기.
a 보여주기.
ok 보여주기.

