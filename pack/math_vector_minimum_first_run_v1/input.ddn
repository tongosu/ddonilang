u <- (3, 4) 차림.
v <- (1, -2) 차림.

ux <- (u, 0) 차림.값.
uy <- (u, 1) 차림.값.
vx <- (v, 0) 차림.값.
vy <- (v, 1) 차림.값.

합 <- (ux + vx, uy + vy) 차림.
차 <- (ux - vx, uy - vy) 차림.
두배 <- (2 * ux, 2 * uy) 차림.
내적 <- ux * vx + uy * vy.
길이제곱 <- ux * ux + uy * uy.

u 보여주기.
v 보여주기.
합 보여주기.
차 보여주기.
두배 보여주기.
내적 보여주기.
길이제곱 보여주기.
