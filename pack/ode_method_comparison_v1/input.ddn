x0 <- 1.
v0 <- 0.
dt <- 0.25.
a0 <- 0 - x0.

명시v1 <- (v0, a0, dt) 적분.오일러.
명시x1 <- (x0, v0, dt) 적분.오일러.
명시에너지1 <- (명시x1 * 명시x1) + (명시v1 * 명시v1).

반쌍1 <- (x0, v0, a0, dt) 적분.반암시적오일러.
반x1 <- (반쌍1, 0) 차림.값.
반v1 <- (반쌍1, 1) 차림.값.
반에너지1 <- (반x1 * 반x1) + (반v1 * 반v1).

"explicit" 보여주기.
명시x1 보여주기.
명시v1 보여주기.
명시에너지1 보여주기.
"semi_implicit" 보여주기.
반x1 보여주기.
반v1 보여주기.
반에너지1 보여주기.

