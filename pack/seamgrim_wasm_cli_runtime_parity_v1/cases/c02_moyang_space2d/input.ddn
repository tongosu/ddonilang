g <- 9.8.
L <- 1.
theta <- 0.65.
omega <- 0.
damp <- 0.02.
dt <- 0.02.
t <- 0.

alpha <- -(g / L) * ((theta) sin) - damp * omega.
omega <- omega + alpha * dt.
theta <- theta + omega * dt.
bob_x <- L * ((theta) sin).
bob_y <- -L * ((theta) cos).

모양 {
  선(0, 0, bob_x, bob_y, 색="#94a3b8", 굵기=0.02).
  원(bob_x, bob_y, r=0.08, 색="#38bdf8", 선색="#0ea5e9", 굵기=0.02).
}.

t 보여주기.
