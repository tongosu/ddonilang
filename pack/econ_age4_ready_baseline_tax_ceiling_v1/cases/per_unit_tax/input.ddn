a <- 100.
b <- 2.
c <- 20.
d <- 2.
tau <- 20.

denom <- b + d.
quantity <- (a - c - tau) / denom.
consumer_price <- a - (b * quantity).
producer_price <- consumer_price - tau.
tax_revenue <- tau * quantity.

