원문 <- "  HeLLo,World  ".
다듬은 <- (원문) 다듬기.
큰글 <- (다듬은) 대문자로바꾸기.
길이 <- (큰글) 길이.
작은글 <- (다듬은) 소문자로바꾸기.
반복글 <- (작은글, 2) 되풀이하기.
조각 <- (큰글, ",") 자르기.
합친 <- (조각, "-") 붙이기.
글자 <- (큰글, 1) 글자뽑기.
찾기 <- (큰글, "WORLD") 찾기.
바꾼 <- (큰글, "WORLD", "YOU") 바꾸기.
큰글 보여주기.
길이 보여주기.
작은글 보여주기.
반복글 보여주기.
합친 보여주기.
글자 보여주기.
찾기 보여주기.
바꾼 보여주기.
