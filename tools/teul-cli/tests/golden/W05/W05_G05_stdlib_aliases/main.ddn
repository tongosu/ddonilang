글 <- "a,b,c".
조각 <- (글, ",") 갈라놓기.
합 <- (조각, "-") 이어붙이기.
길 <- (조각) 길이세기.
둘째 <- (조각, 1) 값뽑기.
팩이름 <- (이름="또니", 점수=75).이름.

x <- -9.
abs <- (x) 절댓값.
sqrt <- (abs) 제곱근.
pow <- (sqrt, 2) 제곱.
max <- (3, 5) 최댓값.
min <- (3, 5) 최솟값.

